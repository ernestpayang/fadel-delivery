{
  "name": "fadel-api",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
  "start": "node src/server.js",
  "server": "nodemon src/server.js",
  "docker:up": "docker-compose up -d",
  "docker:down": "docker-compose down",
  "mobile": "cd mobile && flutter run",
  "dev": "docker-compose up -d && nodemon src/server.js",
  "fadel": "npm run dev & npm run mobile"
},
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@prisma/config": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "nodemon": "^2.0.22",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
